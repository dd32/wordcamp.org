{
	"apiVersion": 2,
	"name": "wordcamp/camptix",
	"title": "Tickets",
	"category": "wordcamp",
	"description": "Display a ticket purchase form for this event.",
	"textdomain": "wordcamporg",
	"attributes": {
		"ticketIds": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		},
		"maxTicketsPerOrder": {
			"type": "number",
			"default": 10
		},
		"coupon": {
			"type": "string",
			"default": ""
		},
		"noTicketsMessage": {
			"type": "string",
			"default": ""
		},
		"eventClosedMessage": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"multiple": false
	},
	"editorScript": "wordcamp-blocks",
	"style": "wordcamp-blocks"
}
