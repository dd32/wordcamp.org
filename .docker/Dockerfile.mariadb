FROM mariadb:11.4

RUN apt-get update && \
    apt-get install -yq --no-install-recommends nano vim && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Set default password
ENV MARIADB_ROOT_PASSWORD=mysql
ENV MARIADB_DATABASE=wordcamp_dev

ADD data/wordcamp_dev.sql /docker-entrypoint-initdb.d/data.sql

EXPOSE 3306
